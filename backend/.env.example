PORT=5000
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/scms?retryWrites=true&w=majority

JWT_SECRET=change-me-long-random-string
JWT_EXPIRES=7d

# Google Sign-In — same Web client ID as the frontend (VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Comma-separated browser origins (Vercel app + local dev)
CLIENT_URL=http://localhost:5173,https://your-app.vercel.app

# Email (Gmail: use an App Password, not your normal password)
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
# If set, new complaints and feedback notifications go here; else falls back to SITE_CONTACT_EMAIL or EMAIL_USER
ADMIN_NOTIFY_EMAIL=

# Optional: SMTP instead of Gmail (when SMTP_HOST + SMTP_USER + SMTP_PASS are set, these take precedence)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="SCMS <noreply@.com>"
APP_NAME=Smart Complaint Management System

# Public contact block (shown on /api/contact-info)
SITE_CONTACT_EMAIL=office@example.com
SITE_CONTACT_PHONE=+1 555 0100
SITE_CONTACT_ADDRESS=123 Main St, City
SITE_CONTACT_NAME=Building administration

# Legacy portal bootstrap (also used to ensure first super admin exists)
ADMIN_PORTAL_EMAIL=kumbhasrinivasarao422@gmail.com
ADMIN_PORTAL_PASSWORD=srinivas@222

# Optional rate limits (per window)
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_API_MAX=400
RATE_LIMIT_CONTACT_MAX=20

NODE_ENV=development
